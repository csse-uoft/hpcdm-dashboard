###  http://ontology.eil.utoronto.ca/Toronto/Toronto#TorChildcareService
:TorChildcareService rdf:type owl:Class ;
                     rdfs:subClassOf <http://ontology.eil.utoronto.ca/HPCDM/ChildcareService> ,
                                     :TorontoService ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty <http://ontology.eil.utoronto.ca/HPCDM/hasServiceRadius> ;
                                       owl:hasValue :childcare_service_radius_default
                                     ] ;
                     rdfs:label "Childcare" ;
                     skos:altLabel "Childcare service" .


